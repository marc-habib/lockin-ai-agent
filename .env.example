# LLM Provider Configuration
# Options: openai, anthropic, google
LLM_PROVIDER=openai

# LLM Model (optional - uses provider default if not specified)
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
# Google: gemini-2.0-flash-exp, gemini-1.5-pro
LLM_MODEL=gpt-4o-mini

# API Keys (provide the one matching your LLM_PROVIDER)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_PATH=data/lockin.db

# OpenFoodFacts API
OPENFOODFACTS_API_URL=https://world.openfoodfacts.org/api/v2

# Cache Settings
CACHE_EXPIRY_DAYS=30

# Agent Settings
MAX_REASONING_STEPS=5
ENABLE_REFLECTION=true

# HuggingFace Spaces (production)
# PORT=7860
